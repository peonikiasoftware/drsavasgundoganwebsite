# ------------------------------------------------------------
# Django
# ------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-generate-with-get_random_secret_key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app
DJANGO_SETTINGS_MODULE=config.settings.dev

# ------------------------------------------------------------
# Database (prod için Supabase Postgres, dev'de SQLite kullanılır)
# Transaction pooler (port 6543) kullan.
# ------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:6543/postgres
# İsteğe bağlı ayrı alanlar:
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=6543

# ------------------------------------------------------------
# Cloudinary (prod için)
# ------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# veya birleşik URL:
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ------------------------------------------------------------
# Admin seed (sadece ilk kurulum için, sonra silinebilir)
# ------------------------------------------------------------
ADMIN_SUPERUSER_USERNAME=murat_admin
ADMIN_SUPERUSER_EMAIL=mrtemroztrk@gmail.com
ADMIN_SUPERUSER_PASSWORD=

DOCTOR_ADMIN_USERNAME=dr_savas
DOCTOR_ADMIN_EMAIL=savas.gundogan@acibadem.com
DOCTOR_ADMIN_PASSWORD=

# ------------------------------------------------------------
# Email (prod için SMTP / Resend / SendGrid)
# ------------------------------------------------------------
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@drsavasgundogan.com
CONTACT_NOTIFICATION_EMAIL=mrtemroztrk@gmail.com

# ------------------------------------------------------------
# Analytics / Tracking (opsiyonel)
# ------------------------------------------------------------
GOOGLE_ANALYTICS_ID=

# ------------------------------------------------------------
# Admin URL (güvenlik için özelleştirilebilir)
# ------------------------------------------------------------
ADMIN_URL_PATH=admin/
